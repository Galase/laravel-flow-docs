{
    "name": "galase/laravel-flow-docs",
    "description": "Static flow documentation generator for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "documentation",
        "static-analysis",
        "flow-docs"
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/routing": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^9.6|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Galase\\FlowDocs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Galase\\FlowDocs\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Galase\\FlowDocs\\FlowDocsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "check": [
            "@php -l src/FlowDocsServiceProvider.php",
            "@php -l src/Console/GenerateFlowDocsCommand.php",
            "@php -l src/FlowDocsGenerator.php",
            "@php -l src/Support/Html/Html.php",
            "@php -l src/Support/Html/HtmlPage.php",
            "@php -l src/Support/I18n/Translator.php",
            "@php -l src/Support/I18n/Languages/pt_BR.php",
            "@php -l src/Support/I18n/Languages/en.php",
            "@php -l src/Support/I18n/Languages/es.php",
            "@php -l src/Support/Analysis/TextAnalyzer.php",
            "@php -l src/Support/Analysis/PhpSourceAnalyzer.php",
            "@php -l src/Support/Analysis/MigrationAnalyzer.php",
            "@php -l src/Support/Analysis/CodeAnalyzer.php",
            "@php -l src/Support/Docs/RootIndexRenderer.php",
            "@php -l src/Support/Docs/ClassDocsGenerator.php",
            "@php -l src/Support/Docs/ModelDocsGenerator.php",
            "@php -l src/Support/Docs/DatabaseDocsGenerator.php",
            "@php -l src/Support/Diagram/DatabaseDiagramBuilder.php",
            "@php -l src/Support/Diagram/DatabaseDiagramRenderer.php"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
